# Status Page Database (separate from main app)
# Supabase: if EHOSTUNREACH, use Connection Pooler (Dashboard → Database → Connection pooling → Transaction)
STATUS_PAGE_DATABASE_URL=postgresql://user:password@host:5432/postgres

# Supabase Auth (same project as Layerly)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Bootstrap (first admin): Dashboard → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cron job security (for /api/cron/check-monitors)
CRON_SECRET=your-cron-secret
